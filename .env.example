# =============================================================================
# Docker Compose environment (copy to `.env` in the repository root).
# Never commit `.env`. Generate secrets: openssl rand -hex 32
# =============================================================================

# --- MySQL 8 (Workbench-compatible: TCP/IP, port 3306, user below) ---
MYSQL_DATABASE=password_security
MYSQL_USER=psc_user
# Must match the password embedded in DATABASE_URI below (URL-encode special chars).
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD_STRONG
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_STRONG
# Host port published to your machine (MySQL Workbench connects here).
MYSQL_PORT=3306

# --- API (Flask / Gunicorn) ---
FLASK_ENV=production
LOG_LEVEL=INFO
SECRET_KEY=CHANGE_ME_SECRET_KEY_32_CHARS_MINIMUM_LENGTH!!
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY_32_CHARS_MINIMUM!!
VAULT_KDF_PEPPER=CHANGE_ME_VAULT_PEPPER_32_CHARS_MINIMUM!!
DATABASE_URI=mysql+pymysql://psc_user:CHANGE_ME_DB_PASSWORD_STRONG@db:3306/password_security
API_PREFIX=/api/v1
# Browser origins allowed to call the API (comma-separated, no spaces). Include SPA URL.
CORS_ORIGINS=http://localhost:8080
# Use redis://redis:6379/0 when you add a Redis service (recommended for multi-worker API).
RATELIMIT_STORAGE_URI=memory://
PASSWORD_HASH_DEFAULT=bcrypt
HIBP_CONNECT_TIMEOUT=3
HIBP_TIMEOUT=5
LOCAL_BREACH_FILE=
LOG_REQUEST_BODY=false

# First admin user (only created when the users table is empty after migrations).
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD_MIN_10_CHARS

# --- Gunicorn ---
GUNICORN_PORT=5000
GUNICORN_WORKERS=3
GUNICORN_THREADS=1
GUNICORN_TIMEOUT=120
DB_HOST=db
DB_PORT=3306
DB_WAIT_SECONDS=90
# Set to 1 only for debugging (skips flask db upgrade on start).
SKIP_MIGRATIONS=0

# --- Web (nginx) published port ---
WEB_PORT=8080
API_PORT=5000
