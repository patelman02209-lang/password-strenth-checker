# =============================================================================
# SECURITY: Copy to `.env` in this directory for local Flask/Vite development.
# For Docker Compose (MySQL + API + nginx), use the repository root `.env.example`
# and copy it to `.env` next to `docker-compose.yml` — see docs/DOCKER.md.
# Never commit `.env`. Production requires HTTPS, strict CORS_ORIGINS, and Redis
# for RATELIMIT_STORAGE_URI when running multiple API workers.
# =============================================================================
FLASK_ENV=development
# All secrets must be >= 32 characters for non-test startup validation.
SECRET_KEY=change-me-to-a-long-random-string-32chars-minimum!!
JWT_SECRET_KEY=change-me-jwt-secret-key-32-characters-minimum!
DATABASE_URI=mysql+pymysql://psc_user:psc_pass@127.0.0.1:3306/password_security
# Used only to derive per-user vault encryption keys (demo: server-side model — see README)
VAULT_KDF_PEPPER=change-me-vault-pepper-min-32-chars-required!!
CORS_ORIGINS=http://localhost:5173
# Public URL prefix for versioned JSON API (default /api/v1)
API_PREFIX=/api/v1
# Flask-Limiter backend (use redis://... in production with multiple workers)
RATELIMIT_STORAGE_URI=memory://
# HIBP Pwned Passwords API timeouts (seconds): (connect, read) used by requests
HIBP_CONNECT_TIMEOUT=3
HIBP_TIMEOUT=5
# Optional: path to HIBP-style SHA-1 hash list (HASH or HASH:count per line) for offline / fallback checks
LOCAL_BREACH_FILE=
# Stored user password algorithm: bcrypt (default) or argon2id
PASSWORD_HASH_DEFAULT=bcrypt
# Bootstrap admin (created on first run if `users` table exists and there are zero users)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeAdmin!123
# Never enable outside local debugging (prevents logging password body lengths)
LOG_REQUEST_BODY=false
# Escape hatch: run SQLAlchemy create_all() in production (not recommended)
# AUTO_DB_CREATE_ALL=1
