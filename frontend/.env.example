# Vite environment (local dev). Copy to `.env` in this directory if you need overrides.
# Docker production builds set VITE_* via Dockerfile ARGs / compose — see ../.env.example and docs/DOCKER.md.

# Leave empty to use same-origin `/api/...` (Vite dev proxy or nginx in Docker).
VITE_API_URL=
VITE_API_PREFIX=/api/v1
